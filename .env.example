# EdgeOne Makers 模型网关配置
AI_GATEWAY_API_KEY=your_api_key_here
AI_GATEWAY_BASE_URL=https://ai-gateway.edgeone.link/v1
AI_GATEWAY_MODEL=@makers/deepseek-v4-flash

# CRM API 配置（替换为你的 CRM 系统地址）
CRM_API_ENDPOINT=https://your-crm-system.com/api/leads
CRM_API_KEY=your_crm_api_key_here

# 品牌配置（不设置则默认 "GEO"）
BRAND_NAME=
AGENT_NAME=
DEFAULT_SOURCE=

# 企业微信配置（如启用企微渠道）
WECOM_CORP_ID=
WECOM_KF_SECRET=
WECOM_APP_SECRET=
WECOM_TOKEN=
WECOM_ENCODING_AES_KEY=

# 腾讯云 Web Search API Key（可选，联网搜索工具需要）
WSA_API_KEY=
